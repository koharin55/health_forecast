<%= turbo_frame_tag "charts" do %>
  <!-- 期間切り替えボタン -->
  <div class="flex flex-wrap gap-2 mb-4 sm:mb-6">
    <% HealthRecord::CHART_PERIODS.each do |key, opt| %>
      <% active = @period == key %>
      <%= link_to opt[:label].sub("最新記録から", ""),
                  root_path(period: key),
                  data: { turbo_frame: "charts" },
                  class: "px-4 py-2 rounded-xl text-sm font-semibold transition-colors #{active ? 'bg-emerald-600 text-white shadow-md' : 'bg-white text-slate-700 border border-slate-200 hover:bg-slate-50'}" %>
    <% end %>
  </div>

  <% if @chart_records.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-8 sm:mb-12">
      <!-- 血圧グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          血圧の推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="bloodPressureChart"></canvas>
        </div>
      </div>

      <!-- 体温グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          体温の推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="bodyTemperatureChart"></canvas>
        </div>
      </div>

      <!-- 睡眠時間グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          睡眠時間の推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="sleepChart"></canvas>
        </div>
      </div>

      <!-- 体重グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          体重の推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="weightChart"></canvas>
        </div>
      </div>

      <!-- 運動時間グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          運動時間の推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="exerciseChart"></canvas>
        </div>
      </div>

      <!-- 体調グラフ -->
      <div class="card rounded-2xl p-4 sm:p-6">
        <h3 class="text-base sm:text-xl font-bold mb-4 sm:mb-6 text-slate-900">
          体調スコアの推移
          <span class="text-xs sm:text-sm font-normal text-slate-500 ml-2"><%= @period_label %></span>
        </h3>
        <div style="height: 200px;">
          <canvas id="moodChart"></canvas>
        </div>
      </div>
    </div>

    <script>
      (() => {
        const chartTimeUnit = <%= raw({ daily: 'day', weekly: 'week', monthly: 'month' }[@chart_interval].to_json) %>;
        // データ準備（集約: <%= @chart_interval %>）
        const weightData = <%= raw chart_series(@chart_records, :weight, interval: @chart_interval).to_json %>;
        const sleepData = <%= raw chart_series(@chart_records, :sleep_minutes, interval: @chart_interval) { |v| (v / 60.0).round(2) }.to_json %>;
        const moodData = <%= raw chart_series(@chart_records, :mood, interval: @chart_interval) { |v| v.round(1) }.to_json %>;
        const exerciseData = <%= raw chart_series(@chart_records, :exercise_minutes, interval: @chart_interval) { |v| v.round(0) }.to_json %>;
        const bloodPressureData = <%= raw chart_blood_pressure_series(@chart_records, interval: @chart_interval).to_json %>;
        const bodyTemperatureData = <%= raw chart_series(@chart_records, :body_temperature, interval: @chart_interval) { |v| v.round(1) }.to_json %>;

        // 既存のチャートを破棄
        ['weightChart', 'sleepChart', 'moodChart', 'exerciseChart', 'bloodPressureChart', 'bodyTemperatureChart'].forEach(id => {
          const canvas = document.getElementById(id);
          if (canvas && Chart.getChart(canvas)) {
            Chart.getChart(canvas).destroy();
          }
        });

        // 体重グラフ（Emeraldグラデーション）
        const weightCtx = document.getElementById('weightChart');
        if (weightCtx && weightData.length > 0) {
          const gradient = weightCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          gradient.addColorStop(0, 'rgba(16, 185, 129, 0.5)');
          gradient.addColorStop(1, 'rgba(16, 185, 129, 0.0)');

          new Chart(weightCtx, {
            type: 'line',
            data: {
              datasets: [{
                label: '体重 (kg)',
                data: weightData,
                borderColor: '#10b981',
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#10b981'
              }]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: { beginAtZero: false }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        // 睡眠時間グラフ（Cyanグラデーション）
        const sleepCtx = document.getElementById('sleepChart');
        if (sleepCtx && sleepData.length > 0) {
          const gradient = sleepCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          gradient.addColorStop(0, 'rgba(6, 182, 212, 0.5)');
          gradient.addColorStop(1, 'rgba(6, 182, 212, 0.0)');

          new Chart(sleepCtx, {
            type: 'line',
            data: {
              datasets: [{
                label: '睡眠時間 (時間)',
                data: sleepData,
                borderColor: '#06b6d4',
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#06b6d4'
              }]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: { beginAtZero: true }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        // 体調グラフ（Amberグラデーション、y軸1-5固定）
        const moodCtx = document.getElementById('moodChart');
        if (moodCtx && moodData.length > 0) {
          const gradient = moodCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          gradient.addColorStop(0, 'rgba(245, 158, 11, 0.5)');
          gradient.addColorStop(1, 'rgba(245, 158, 11, 0.0)');

          new Chart(moodCtx, {
            type: 'line',
            data: {
              datasets: [{
                label: '体調スコア',
                data: moodData,
                borderColor: '#f59e0b',
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#f59e0b'
              }]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: { min: 1, max: 5, ticks: { stepSize: 1 } }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        // 運動時間グラフ（棒グラフ、Emerald-Cyanグラデーション）
        const exerciseCtx = document.getElementById('exerciseChart');
        if (exerciseCtx && exerciseData.length > 0) {
          const gradient = exerciseCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          gradient.addColorStop(0, 'rgba(16, 185, 129, 0.8)');
          gradient.addColorStop(1, 'rgba(6, 182, 212, 0.8)');

          new Chart(exerciseCtx, {
            type: 'bar',
            data: {
              datasets: [{
                label: '運動時間 (分)',
                data: exerciseData,
                backgroundColor: gradient,
                borderColor: '#10b981',
                borderWidth: 1
              }]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: { beginAtZero: true }
              },
              plugins: { legend: { display: false } }
            }
          });
        }

        // 血圧グラフ（最高血圧・最低血圧の2本線）
        const bloodPressureCtx = document.getElementById('bloodPressureChart');
        if (bloodPressureCtx && bloodPressureData.length > 0) {
          // 最高血圧用グラデーション
          const systolicGradient = bloodPressureCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          systolicGradient.addColorStop(0, 'rgba(244, 63, 94, 0.5)');
          systolicGradient.addColorStop(1, 'rgba(244, 63, 94, 0.0)');

          // 最低血圧用グラデーション
          const diastolicGradient = bloodPressureCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          diastolicGradient.addColorStop(0, 'rgba(99, 102, 241, 0.5)');
          diastolicGradient.addColorStop(1, 'rgba(99, 102, 241, 0.0)');

          new Chart(bloodPressureCtx, {
            type: 'line',
            data: {
              datasets: [
                {
                  label: '最高血圧 (mmHg)',
                  data: bloodPressureData.map(d => ({ x: d.x, y: d.systolic })),
                  borderColor: '#f43f5e',
                  backgroundColor: systolicGradient,
                  fill: true,
                  tension: 0.4,
                  pointRadius: 4,
                  pointBackgroundColor: '#f43f5e'
                },
                {
                  label: '最低血圧 (mmHg)',
                  data: bloodPressureData.map(d => ({ x: d.x, y: d.diastolic })),
                  borderColor: '#6366f1',
                  backgroundColor: diastolicGradient,
                  fill: true,
                  tension: 0.4,
                  pointRadius: 4,
                  pointBackgroundColor: '#6366f1'
                }
              ]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: {
                  beginAtZero: false,
                  min: 40,
                  max: 180,
                  ticks: { stepSize: 20 }
                }
              },
              plugins: {
                legend: {
                  display: true,
                  position: 'top',
                  labels: {
                    boxWidth: 12,
                    padding: 10,
                    font: { size: 11 }
                  }
                }
              }
            }
          });
        }

        // 体温グラフ（Purpleグラデーション）
        const bodyTemperatureCtx = document.getElementById('bodyTemperatureChart');
        if (bodyTemperatureCtx && bodyTemperatureData.length > 0) {
          const gradient = bodyTemperatureCtx.getContext('2d').createLinearGradient(0, 0, 0, 250);
          gradient.addColorStop(0, 'rgba(168, 85, 247, 0.5)');
          gradient.addColorStop(1, 'rgba(168, 85, 247, 0.0)');

          new Chart(bodyTemperatureCtx, {
            type: 'line',
            data: {
              datasets: [{
                label: '体温 (℃)',
                data: bodyTemperatureData,
                borderColor: '#a855f7',
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#a855f7'
              }]
            },
            options: {
              animation: { duration: 0 },
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                x: { type: 'time', time: { unit: chartTimeUnit } },
                y: {
                  beginAtZero: false,
                  min: 34,
                  max: 40,
                  ticks: { stepSize: 1 }
                }
              },
              plugins: { legend: { display: false } }
            }
          });
        }
      })();
    </script>
  <% else %>
    <div class="card rounded-2xl p-8 text-center text-slate-500 mb-8">
      この期間には記録がありません
    </div>
  <% end %>
<% end %>
